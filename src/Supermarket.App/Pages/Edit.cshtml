@page "{id:int}"
@model EditModel
@{ ViewData["Title"] = "Edit product"; }

<h2 class="mb-3">Edit product #@Model.Input.Id</h2>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Input.Id" />
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input class="form-control" asp-for="Input.Name" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">Brand</label>
                <input class="form-control" asp-for="Input.Brand" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Barcode</label>
                <input class="form-control" asp-for="Input.Barcode" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Price</label>
                <input class="form-control" type="number" step="0.01" asp-for="Input.Price" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Quantity</label>
                <input class="form-control" type="number" asp-for="Input.Quantity" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Expiry date</label>
                <input class="form-control" type="date" asp-for="Input.ExpiryDate" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Category</label>
                <select class="form-select" asp-for="Input.CategoryId" required>
                    @foreach (var c in Model.Categories) { <option value="@c.Id">@c.Name</option> }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Supplier</label>
                <select class="form-select" asp-for="Input.SupplierId" required>
                    @foreach (var s in Model.Suppliers) { <option value="@s.Id">@s.Name</option> }
                </select>
            </div>
            <div class="col-12">
                <button class="btn btn-success">Save changes</button>
                <a class="btn btn-outline-secondary" asp-page="/Products">Cancel</a>
            </div>
        </form>
    </div>
</div>
