@page
@model CatalogModel
@{ ViewData["Title"] = "Categories & Suppliers"; }

<h2 class="mb-3">Categories &amp; Suppliers</h2>

@if (Model.Message != null) { <div class="alert alert-success">@Model.Message</div> }
@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Categories</div>
            <div class="card-body">
                <form method="post" asp-page-handler="AddCategory" class="input-group mb-3">
                    <input class="form-control" name="name" placeholder="New category" required />
                    <button class="btn btn-success">Add</button>
                </form>
                <table class="table table-sm align-middle">
                    @foreach (var c in Model.Categories)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>
                                <form method="post" asp-page-handler="RenameCategory" asp-route-id="@c.Id" class="input-group input-group-sm">
                                    <input class="form-control" name="name" value="@c.Name" required />
                                    <button class="btn btn-outline-primary">Save</button>
                                </form>
                            </td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="DeleteCategory" asp-route-id="@c.Id">
                                    <button class="btn btn-sm btn-outline-danger">Delete</button></form>
                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Suppliers</div>
            <div class="card-body">
                <form method="post" asp-page-handler="AddSupplier" class="row g-2 mb-3">
                    <div class="col"><input class="form-control" name="name" placeholder="Name" required /></div>
                    <div class="col"><input class="form-control" name="contact" placeholder="Contact" /></div>
                    <div class="col-auto"><button class="btn btn-success">Add</button></div>
                </form>
                <table class="table table-sm align-middle">
                    @foreach (var s in Model.Suppliers)
                    {
                        <tr>
                            <td>@s.Id</td>
                            <td colspan="2">
                                <form method="post" asp-page-handler="EditSupplier" asp-route-id="@s.Id" class="row g-1">
                                    <div class="col"><input class="form-control form-control-sm" name="name" value="@s.Name" required /></div>
                                    <div class="col"><input class="form-control form-control-sm" name="contact" value="@s.Contact" placeholder="Contact" /></div>
                                    <div class="col-auto"><button class="btn btn-sm btn-outline-primary">Save</button></div>
                                </form>
                            </td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="DeleteSupplier" asp-route-id="@s.Id">
                                    <button class="btn btn-sm btn-outline-danger">Delete</button></form>
                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>
</div>
