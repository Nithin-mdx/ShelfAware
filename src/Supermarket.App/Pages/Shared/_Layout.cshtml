<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShelfAware</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">🛒 ShelfAware</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Index">Dashboard</a>
                <a class="nav-link" asp-page="/Products">Products</a>
                <a class="nav-link" asp-page="/Catalog">Categories &amp; Suppliers</a>
                <a class="nav-link" asp-page="/Stock">Stock</a>
                <a class="nav-link" asp-page="/Search">Search</a>
                <a class="nav-link" asp-page="/Sell">Sell</a>
                <a class="nav-link" asp-page="/Sales">Sales</a>
                <a class="nav-link" asp-page="/Reports">Reports</a>
            </div>
        </div>
    </nav>
    <main class="container py-4">
        @RenderBody()
    </main>
</body>
</html>
