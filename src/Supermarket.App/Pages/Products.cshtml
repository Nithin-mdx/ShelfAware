@page
@model ProductsModel
@{ ViewData["Title"] = "Products"; }

<h2 class="mb-3">Products</h2>

@if (Model.Message != null) { <div class="alert alert-success">@Model.Message</div> }
@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold">Add product</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Add" class="row g-2">
            <div class="col-md-3"><input class="form-control" asp-for="Input.Name" placeholder="Name" required /></div>
            <div class="col-md-2"><input class="form-control" asp-for="Input.Brand" placeholder="Brand" /></div>
            <div class="col-md-2"><input class="form-control" asp-for="Input.Barcode" placeholder="Barcode" required /></div>
            <div class="col-md-1"><input class="form-control" type="number" step="0.01" asp-for="Input.Price" placeholder="Price" /></div>
            <div class="col-md-1"><input class="form-control" type="number" asp-for="Input.Quantity" placeholder="Qty" /></div>
            <div class="col-md-3"><input class="form-control" type="date" asp-for="Input.ExpiryDate" /></div>
            <div class="col-md-3">
                <select class="form-select" asp-for="Input.CategoryId" required>
                    <option value="">-- Category --</option>
                    @foreach (var c in Model.Categories) { <option value="@c.Id">@c.Name</option> }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" asp-for="Input.SupplierId" required>
                    <option value="">-- Supplier --</option>
                    @foreach (var s in Model.Suppliers) { <option value="@s.Id">@s.Name</option> }
                </select>
            </div>
            <div class="col-md-2"><button class="btn btn-success w-100">Add</button></div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover bg-white shadow-sm">
    <thead class="table-dark">
        <tr><th>Id</th><th>Name</th><th>Barcode</th><th>Price</th><th>Qty</th><th>Category</th><th>Supplier</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var p in Model.All)
    {
        <tr class="@(p.IsLowStock() ? "table-warning" : "")">
            <td>@p.Id</td><td>@p.Name</td><td>@p.Barcode</td><td>@p.Price.ToString("0.00")</td>
            <td>@p.Quantity @(p.IsLowStock() ? "⚠️" : "")</td>
            <td>@p.Category?.Name</td><td>@p.Supplier?.Name</td>
            <td class="d-flex gap-1">
                <a class="btn btn-sm btn-outline-primary" asp-page="/Edit" asp-route-id="@p.Id">Edit</a>
                <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id"
                      onsubmit="return confirm('Delete @p.Name?');">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
